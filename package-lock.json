{
  "name": "ranksmith",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ranksmith",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "packages/indexing/*"
      ],
      "devDependencies": {
        "typescript": "^5.9.2"
      }
    },
    "apps/api": {
      "name": "@ranksmith/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@ranksmith/web",
      "version": "0.1.0"
    },
    "node_modules/@ranksmith/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@ranksmith/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@ranksmith/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/core": {
      "name": "@ranksmith/core",
      "version": "0.1.0"
    }
  }
}
